    "%@, %@" : {
      "comment" : "A button that, when tapped, presents a sheet allowing the user to edit a specific detail of an episode. The first argument is the localized title of the episode detail. The second argument is the localized text that currently represents the value of that detail.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@, %2$@"
          }
        }
      }
    },
    "%@, %@, %@%@" : {
      "comment" : "A label describing a choice in a compact choice group. The first argument is the title of the block the choice is in. The second argument is the title of the choice. The third argument is a string indicating whether the choice is selected.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
