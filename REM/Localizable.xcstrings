      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smelling odors that have no real source in the environment."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentir cheiros que não têm fonte real no ambiente."
          }
        }
      }
    },
    "experience.description.oralObstruction" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inability to breathe through the mouth because it feels closed or blocked."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossibilidade de respirar pela boca porque parece fechada ou bloqueada."
