      }
    },
    "experience.description.outOfBodyExperience" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sense that your consciousness or perspective is floating outside your physical body."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensação de que sua consciência ou perspectiva está flutuando fora do corpo físico."
          }
        }
      }
    },
    "experience.description.palpitation" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensation of rapid, fluttering, or irregular heartbeat."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensação de batimento cardíaco rápido, acelerado ou irregular."
          }
        }
      }
    },
    "experience.description.panic" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sudden wave of extreme fear or anxiety, often overwhelming."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Onda súbita de medo ou ansiedade extrema, geralmente avassaladora."
          }
        }
      }
    },
    "experience.description.proprioceptiveDistortion" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perception that your limbs or body are unnaturally larger, smaller, or out of place."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Percepção de que seus membros ou corpo estão exageradamente maiores, menores ou fora de lugar."
          }
        }
      }
    },
    "experience.description.thermalSensation" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feeling sudden heat or cold on the skin without a real temperature change."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentir calor ou frio intenso na pele sem mudança real de temperatura."
