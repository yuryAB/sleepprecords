          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensação de um peso intenso pressionando o corpo."
          }
        }
      }
    },
    "experience.description.calm" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An unusual sense of peace and tranquility despite paralysis."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensação incomum de paz e tranquilidade mesmo durante a paralisia."
          }
        }
      }
    },
    "experience.description.compression" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feeling as if your torso or chest is being tightly squeezed or bound."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensação de que o tórax ou o corpo está sendo apertado ou amarrado com força."
          }
        }
      }
    },
    "experience.description.crawlingBiting" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feeling as if insects are crawling on your skin or biting you."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensação de que insetos estão rastejando na pele ou mordendo você."
          }
        }
      }
    },
    "experience.description.drowningSinking" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feeling as though you are sinking underwater or being pulled down, making it hard to breathe."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensação de que você está se afundando na água ou sendo puxado para baixo, dificultando a respiração."
          }
        }
      }
    },
    "experience.description.externalObstruction" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Difficulty breathing because an object (e.g., pillow, blanket) seems to cover or press on you."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dificuldade para respirar porque um objeto (por ex., travesseiro, coberta) parece cobrir ou pressionar você."
          }
        }
      }
    },
    "experience.description.externalTouch" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feeling as if someone or something is touching or pressing on your skin."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensação de que algo ou alguém está tocando ou pressionando sua pele."
          }
        }
      }
    },
    "experience.description.falling" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sudden feeling of dropping or falling, despite lying still."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sensação súbita de cair ou despencar, mesmo estando imóvel."
          }
