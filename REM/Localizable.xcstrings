      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inability to breathe through the nose due to a feeling of blockage."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossibilidade de respirar pelo nariz devido à sensação de bloqueio."
